# Anthropic API key — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=your_api_key_here

# HMAC-SHA256 secret used to sign time-bounded tokens for AI route authorization.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Prefixed NEXT_PUBLIC_ so the client can sign requests; rotate this if exposed.
NEXT_PUBLIC_MARKET_PLAIN_API_SECRET=generate_a_random_32_byte_hex_string

# Comma-separated list of Pro access tokens checked server-side on all AI routes.
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
# Add a token here, then set localStorage key "pro-token" to that value in the browser.
# Multiple tokens supported: token1,token2,token3
PRO_BYPASS_TOKENS=generate_a_random_token

# Server-only secret used to sign Stripe Pro tokens — never expose to the client.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PRO_TOKEN_SECRET=generate_a_random_32_byte_hex_string

# Stripe — get these from https://dashboard.stripe.com/apikeys and your webhook settings.
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price ID from your Stripe product — looks like price_1ABC...
STRIPE_PRICE_ID=price_...
